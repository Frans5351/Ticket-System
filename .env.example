# Local-dev env vars for Netlify Dev (cp this to .env in the project root,
# then run `netlify dev`). NEVER commit the real values.

# Passkey config — localhost-specific
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Park Manor (dev)
PASSKEY_ORIGIN=http://localhost:8888

# Use any long random string here for local dev. Different from production.
# Generate with: openssl rand -hex 32
PASSKEY_JWT_SECRET=replace-me-with-a-long-random-string

# Supabase service role key — same key as production (the local functions
# point at the same Supabase project). Get it from Supabase → Project Settings
# → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-supabase-service-role-key

# Optional override (defaults to the hardcoded URL in _passkey-shared.js)
# SUPABASE_URL=https://spagcmzhlngtqvrydzvi.supabase.co
